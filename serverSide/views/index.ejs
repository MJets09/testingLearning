<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Quotes</title>
</head>

<body>
    <h1> May Node and Express be with you. Stay focused.</h1>
    <form action="/quotes" method="POST">
        <input type="text" name="name" id="" placeholder="name">
        <input type="text" name="quote" id="" placeholder="quote">
        <button type="submit"> Submit</button>
        <h2> Quotes </h2>

        <ul class="quotes">
            <!-- Loop through quotes -->
            <% for(var i = 0; i < quotes.length; i++) {%>
                <li class="quote">
                    <!-- Output name from the iterated quote object -->
                    <span><%= quotes[i].name %></span>:
                    <!-- Output quote from the iterated quote object -->
                    <span><%= quotes[i].quote %></span>
                </li>
                <% } %>
        </ul>
    </form>
</body>

</html>